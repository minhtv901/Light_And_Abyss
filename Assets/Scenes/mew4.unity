MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 703755411}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8411e781379541744a845259dfcfc0c6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BossDefeatChoiceDialogue
  dialoguePanel: {fileID: 440867603}
  speakerText: {fileID: 1573735422}
  dialogueText: {fileID: 1321544847}
  choiceButtons:
  - {fileID: 1048367731}
  - {fileID: 447817054}
  - {fileID: 614563435}
  choiceButtonTexts:
  - {fileID: 285332593}
  - {fileID: 508412047}
  - {fileID: 1068929454}
  showResultPanel: 1
  resultPanel: {fileID: 1123047048}
  resultText: {fileID: 1682704018}
  resultShowDuration: 5
  steps:
  - speakerName: Boss
    dialogueText: "Ng\u01B0\u01A1i \u0111\xE3 m\u1EA1nh t\u1EDBi m\u1EE9c n\xE0y...
      Ch\xFAng ta c\xF3 c\xE1ch khi\u1EBFn ng\u01B0\u01A1i m\u1EA1nh h\u01A1n, t\u1EA1i
      sao ng\u01B0\u01A1i kh\xF4ng c\xF9ng ch\xFAng ta th\u1ED1ng tr\u1ECB?"
    choices:
    - choiceText: "C\xE1c ng\u01B0\u01A1i c\xF3 th\u1EC3 gi\xFAp ta m\u1EA1nh h\u01A1n
        sao?"
      darkPoint: 1
      purifiedPoint: 0
      tieBreakerBias: 2
    - choiceText: "Ta s\u1EBD d\xF9ng s\u1EE9c m\u1EA1nh n\xE0y \u0111\u1EC3 b\u1EA3o
        v\u1EC7 m\u1ECDi ng\u01B0\u1EDDi."
      darkPoint: 0
      purifiedPoint: 1
      tieBreakerBias: 1
    - choiceText: "Ta s\u1EBD t\u1EF1 quy\u1EBFt \u0111\u1ECBnh c\xE1ch d\xF9ng s\u1EE9c
        m\u1EA1nh n\xE0y."
      darkPoint: 1
      purifiedPoint: 1
      tieBreakerBias: 0
  - speakerName: Boss
    dialogueText: "\xC1nh s\xE1ng y\u1EBFu \u0111u\u1ED1i. B\xF3ng t\u1ED1i m\u1EDBi
      l\xE0 th\u1EE9 gi\xFAp ng\u01B0\u01A1i s\u1ED1ng s\xF3t."
    choices:
    - choiceText: "B\xF3ng t\u1ED1i s\u1EBD gi\xFAp ta m\u1EA1nh h\u01A1n sao."
      darkPoint: 1
      purifiedPoint: 0
      tieBreakerBias: 2
    - choiceText: "Kh\xF4ng. Ta s\u1EBD c\xF9ng m\u1ECDi ng\u01B0\u1EDDi \u0111\xE1nh
        b\u1EA1i ma v\u01B0\u01A1ng, c\xF9ng nhau s\u1ED1ng s\xF3t."
      darkPoint: 0
      purifiedPoint: 1
      tieBreakerBias: 1
    - choiceText: "B\xF3ng t\xF4i hay \xE1nh s\xE1ng, ta c\u0169ng kh\xF4ng ch\u1EAFc
        n\u1EEFa..."
      darkPoint: 1
      purifiedPoint: 1
      tieBreakerBias: 0
  - speakerName: Boss
    dialogueText: "Theo ta. Ta s\u1EBD cho ng\u01B0\u01A1i quy\u1EC1n n\u0103ng v\u01B0\u1EE3t
      qua m\u1ECDi gi\u1EDBi h\u1EA1n."
    choices:
    - choiceText: "N\u1EBFu \u0111\xF3 l\xE0 c\xE1i gi\xE1 \u0111\u1EC3 m\u1EA1nh
        h\u01A1n."
      darkPoint: 1
      purifiedPoint: 0
      tieBreakerBias: 2
    - choiceText: "Ta s\u1EBD kh\xF4ng \u0111\xE1nh m\u1EA5t ch\xEDnh m\xECnh."
      darkPoint: 0
      purifiedPoint: 1
      tieBreakerBias: 1
    - choiceText: "S\u1EE9c m\u1EA1nh l\xE0 th\u1EE9 ta nh\u1EA5t \u0111\u1ECBnh
        s\u1EBD \u0111\u1EA1t \u0111\u01B0\u1EE3c, nh\u01B0ng ta s\u1EBD kh\xF4ng
        theo ng\u01B0\u01A1i."
      darkPoint: 1
      purifiedPoint: 1
      tieBreakerBias: 0
  - speakerName: Boss
    dialogueText: "V\u1EADy h\xE3y ch\u1ECDn \u0111i. Ng\u01B0\u01A1i s\u1EBD b\u01B0\u1EDBc
      ti\u1EBFp b\u1EB1ng \xE1nh s\xE1ng... hay b\xF3ng t\u1ED1i?"
    choices:
    - choiceText: "Ta s\u1EBD tr\u1EDF n\xEAn m\u1EA1nh m\u1EBD v\xE0 h\u1EE7y di\u1EC7t
        t\u1EA5t c\u1EA3"
      darkPoint: 1
      purifiedPoint: 0
      tieBreakerBias: 2
    - choiceText: "Ta s\u1EBD kh\xF4ng \u0111\u1EC3 b\xF3ng t\u1ED1i v\u1EA5y b\u1EA9n."
      darkPoint: 0
      purifiedPoint: 1
      tieBreakerBias: 1
  playerMovement: {fileID: 1738113455}
  bossObjectToDisable: {fileID: 0}
  gateToOpen: {fileID: 0}
  pauseGameWhileChoosing: 1
  hideBossAfterChoice: 1
  openGateAfterChoice: 1
  debugLog: 1
